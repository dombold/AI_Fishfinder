generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: SQLite does not support enums; stored as String with validation in app layer

model User {
  id                   String            @id @default(cuid())
  username             String            @unique
  email                String            @unique
  passwordHash         String
  sounderType          String            @default("NONE")
  seasicknessTolerance Int               @default(3)
  weeklyDigestOptIn    Boolean           @default(false)
  avatar               String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  sessions             FishingSession[]
  catchLogs            CatchLog[]
  ownedGroups          Group[]           @relation("GroupOwner")
  memberships          GroupMembership[] @relation("GroupMemberships")

  @@map("users")
}

model FishingSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude        Float
  longitude       Float
  locationName    String?
  startDate       String
  endDate         String
  fishingType     String
  targetType      String
  status          String   @default("PENDING")
  errorMessage    String?
  saved           Boolean  @default(false)
  contextData     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  selectedSpecies SelectedSpecies[]
  marineData      MarineData[]
  fishingPlans    FishingPlan[]

  @@index([userId])
  @@map("fishing_sessions")
}

model SelectedSpecies {
  id          String         @id @default(cuid())
  sessionId   String
  session     FishingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speciesName String

  @@index([sessionId])
  @@map("selected_species")
}

model MarineData {
  id               String         @id @default(cuid())
  sessionId        String
  session          FishingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date             String
  willyWeatherData String
  openMeteoData    String
  tideData         String
  sstGrid          String?        // JSON: SSTGridPoint[] — nullable for backwards compat
  fetchedAt        DateTime       @default(now())

  @@unique([sessionId, date])
  @@index([sessionId])
  @@map("marine_data")
}

model FishingPlan {
  id          String         @id @default(cuid())
  sessionId   String
  session     FishingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date        String
  planContent String
  generatedAt DateTime       @default(now())

  @@unique([sessionId, date])
  @@index([sessionId])
  @@map("fishing_plans")
}

model CatchLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  latitude  Float
  longitude Float
  species   String
  quantity  Int      @default(1)
  weightKg  Float?
  lengthCm  Float?
  notes     String?
  bioregion     String?
  source        String?   // null = user-submitted; 'recfishwest-newsletter' = from weekly report
  captureTime   String?   // HH:MM local time from photo EXIF
  fishCount     Int?      // AI-counted fish in photo
  environment   String?   // beach | boat | jetty | rocks | reef | unknown
  fishingMethod String?   // lure | bait | fly | unknown
  sst           Float?    // Sea surface temperature in °C at time of catch
  tideDirection String?   // incoming | outgoing | slack
  moonPhase     String?   // e.g. Waxing Gibbous, Full Moon
  waterDepthM   Float?    // Water depth in metres at catch location (from GEBCO bathymetry)
  photoBase64   String?   // Resized JPEG/PNG as base64, captured at time of logging
  shared        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([bioregion])
  @@index([bioregion, species])
  @@map("catch_logs")
}

model Group {
  id          String            @id @default(cuid())
  name        String
  avatar      String?
  ownerId     String
  owner       User              @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships GroupMembership[]
  createdAt   DateTime          @default(now())

  @@index([ownerId])
  @@map("groups")
}

model GroupMembership {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING")  // "PENDING" | "ACTIVE"
  createdAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
  @@map("group_memberships")
}

model NewsletterFetch {
  id               String   @id @default(cuid())
  source           String   // 'recfishwest'
  url              String   @unique
  publishedDate    String   // YYYY-MM-DD
  fetchedAt        DateTime @default(now())
  observationCount Int

  @@map("newsletter_fetches")
}

model CrowdSourceSummary {
  id          String   @id @default(cuid())
  bioregion   String   @unique
  updatedAt   DateTime @updatedAt
  summaryJson String

  @@map("crowd_source_summaries")
}
