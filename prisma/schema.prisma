generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: SQLite does not support enums; stored as String with validation in app layer

model User {
  id                   String           @id @default(cuid())
  username             String           @unique
  email                String           @unique
  passwordHash         String
  sounderType          String           @default("NONE")
  seasicknessTolerance Int              @default(3)
  weeklyDigestOptIn    Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  sessions             FishingSession[]
  catchLogs            CatchLog[]

  @@map("users")
}

model FishingSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude        Float
  longitude       Float
  locationName    String?
  startDate       String
  endDate         String
  fishingType     String
  targetType      String
  status          String   @default("PENDING")
  errorMessage    String?
  saved           Boolean  @default(false)
  contextData     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  selectedSpecies SelectedSpecies[]
  marineData      MarineData[]
  fishingPlans    FishingPlan[]

  @@index([userId])
  @@map("fishing_sessions")
}

model SelectedSpecies {
  id          String         @id @default(cuid())
  sessionId   String
  session     FishingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speciesName String

  @@index([sessionId])
  @@map("selected_species")
}

model MarineData {
  id               String         @id @default(cuid())
  sessionId        String
  session          FishingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date             String
  willyWeatherData String
  openMeteoData    String
  tideData         String
  fetchedAt        DateTime       @default(now())

  @@unique([sessionId, date])
  @@index([sessionId])
  @@map("marine_data")
}

model FishingPlan {
  id          String         @id @default(cuid())
  sessionId   String
  session     FishingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date        String
  planContent String
  generatedAt DateTime       @default(now())

  @@unique([sessionId, date])
  @@index([sessionId])
  @@map("fishing_plans")
}

model CatchLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  latitude  Float
  longitude Float
  species   String
  quantity  Int      @default(1)
  weightKg  Float?
  lengthCm  Float?
  notes     String?
  bioregion String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([bioregion])
  @@index([bioregion, species])
  @@map("catch_logs")
}

model InatObservation {
  id           String   @id
  taxonName    String
  appSpecies   String?
  bioregion    String
  latitude     Float
  longitude    Float
  observedOn   String
  qualityGrade String
  fetchedAt    DateTime @default(now())

  @@index([bioregion])
  @@index([bioregion, appSpecies])
  @@index([observedOn])
  @@map("inat_observations")
}

model CrowdSourceSummary {
  id          String   @id @default(cuid())
  bioregion   String   @unique
  updatedAt   DateTime @updatedAt
  summaryJson String

  @@map("crowd_source_summaries")
}
