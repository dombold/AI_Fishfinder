# Database (PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/ai_fishfinder"

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# WillyWeather API — https://www.willyweather.com.au/info/api.html
WILLYWEATHER_API_KEY="your-key-here"

# Email (SMTP) — used for welcome emails and weekly digest
# Works with any SMTP provider: Gmail, Mailgun, Postmark, Brevo, etc.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"          # true for port 465 (SSL), false for 587 (STARTTLS)
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="AI Fishfinder <noreply@yourdomain.com.au>"

# Contact page — support email address displayed on /contact
CONTACT_EMAIL="your@email.com"
